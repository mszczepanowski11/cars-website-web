{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node -e \"process.on('uncaughtException',e=>console.error('CRASH:',e.message,e.stack));process.on('unhandledRejection',e=>console.error('REJECT:',e));import('./.output/server/index.mjs').then(()=>console.log('IMPORT OK')).catch(e=>console.error('IMPORT FAIL:',e.message,e.stack))\"",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
