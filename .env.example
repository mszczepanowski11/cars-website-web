# =============================================================
# CARIZO — Zmienne środowiskowe
# Skopiuj ten plik jako .env i uzupełnij wartości
# =============================================================

# --- Backend API ---
# URL backendu ASP.NET Core (z ukośnikiem na końcu)
NUXT_PUBLIC_API_BASE=https://api.carizo.pl/

# --- Strona ---
NUXT_PUBLIC_SITE_URL=https://carizo.pl

# --- Sesja (zmień na losowy ciąg min. 32 znaków) ---
NUXT_SESSION_PASSWORD=ZMIEN_NA_LOSOWY_CIAG_ZNAKOW_MIN_32

# --- Premiery (format ISO 8601 ze strefą czasową) ---
# Ustaw daty okresu premiere lub usuń aby wyłączyć
NUXT_PUBLIC_PREMIERE_START=2026-07-01T00:00:00+02:00
NUXT_PUBLIC_PREMIERE_END=2026-07-07T23:59:59+02:00

# --- Analityka (zostaw puste aby wyłączyć) ---
NUXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NUXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NUXT_PUBLIC_META_PIXEL_ID=
NUXT_PUBLIC_CLARITY_ID=

# --- Social media (zostaw puste aby ukryć w stopce) ---
NUXT_PUBLIC_SOCIAL_FACEBOOK=https://facebook.com/carizo
NUXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/carizo
NUXT_PUBLIC_SOCIAL_TIKTOK=https://tiktok.com/@carizo
NUXT_PUBLIC_SOCIAL_YOUTUBE=
